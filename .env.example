# Copy this file to `.env` and fill in values. Never commit `.env`.

# Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional (defaults are fine if omitted):
# GEMINI_MODEL=gemini-2.5-flash
# Absolute path to a custom system prompt (UTF-8). Overrides bundled prompts/analysis_system.txt (ja)
# GEMINI_SYSTEM_PROMPT_FILE=
# Same for English UI (overrides prompts/analysis_system_en.txt)
# GEMINI_SYSTEM_PROMPT_FILE_EN=
